<!DOCTYPE html>
<html lang="az">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Al Eye – Moda və Alış-Veriş Modulu</title>
  <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-gray-50 text-gray-800">
  <div class="max-w-4xl mx-auto p-6">
    <div class="bg-white rounded-2xl shadow-xl p-6">
      <div class="flex items-center justify-between mb-6">
        <h1 class="text-2xl font-bold text-pink-700">👗 Al Eye – Moda və Stil Məsləhətləri</h1>
        <span class="text-sm text-blue-600">AI Stilist Aktivdir</span>
      </div>

      <!-- Cari geyim qiymətləndirilməsi -->
      <div class="mb-6">
        <h2 class="text-xl font-semibold mb-3">👀 Geyimin qiymətləndirilməsi</h2>
        <div class="bg-gray-100 p-4 rounded-xl">
          <p class="mb-2">Hazırkı geyimin:</p>
          <ul class="list-disc list-inside text-gray-700">
            <li>Stil: Rahat gündəlik</li>
            <li>Uyğunluq: 80% uyğun</li>
            <li>Rəng balansı: Pastel tonlar (mükəmməl)</li>
          </ul>
          <p class="mt-3 italic text-green-700">“Bu görünüş sənə yaraşır! Sadəcə kiçik bir aksesuarla tamamlana bilər.”</p>
        </div>
      </div>

      <!-- Stil təklifi -->
      <div class="mb-6">
        <h2 class="text-xl font-semibold mb-3">🎨 Stil və kombin təklifi</h2>
        <div class="grid grid-cols-2 gap-4">
          <div class="bg-yellow-100 p-4 rounded-xl">
            <h3 class="font-bold">Klassik gündəlik</h3>
            <ul class="text-sm mt-2">
              <li>✔ Açıq krem bluz</li>
              <li>✔ Tünd mavi cins şalvar</li>
              <li>✔ Bej ayaqqabı</li>
              <li>✔ Qızılı saat</li>
            </ul>
          </div>
          <div class="bg-purple-100 p-4 rounded-xl">
            <h3 class="font-bold">Axşam şıklığı</h3>
            <ul class="text-sm mt-2">
              <li>✔ Qara sadə don</li>
              <li>✔ Gümüşü sırğalar</li>
              <li>✔ Topuqdan bağlı ayaqqabı</li>
              <li>✔ Mini çanta</li>
            </ul>
          </div>
        </div>
      </div>

      <!-- Alış-veriş bağlantısı -->
      <div class="mb-6">
        <h2 class="text-xl font-semibold mb-3">🛒 Tövsiyə olunan məhsullar</h2>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
          <div class="border rounded-xl p-4 shadow-sm">
            <img src="https://via.placeholder.com/150x200" alt="Product" class="mb-2 rounded-lg">
            <h3 class="text-lg font-semibold">Krem Bluz</h3>
            <p class="text-sm text-gray-600">ZARA – 49.99 ₼</p>
            <a href="#" class="text-pink-600 text-sm underline">Sayta keç</a>
          </div>
          <div class="border rounded-xl p-4 shadow-sm">
            <img src="https://via.placeholder.com/150x200" alt="Product" class="mb-2 rounded-lg">
            <h3 class="text-lg font-semibold">Qara Don</h3>
            <p class="text-sm text-gray-600">Mango – 89.99 ₼</p>
            <a href="#" class="text-pink-600 text-sm underline">Sayta keç</a>
          </div>
        </div>
      </div>

      <!-- Stil sualı -->
      <div>
        <h2 class="text-xl font-semibold mb-3">❓ Stil seçimində kömək istəyirsən?</h2>
        <textarea
          placeholder="Məsələn: 'Toy üçün nə geyinim?' və ya 'Bu don mənə yaraşır?'"
          class="w-full p-4 rounded-xl border border-gray-300 focus:ring-pink-400"
          rows="3"
        ></textarea>
        <button class="mt-4 bg-pink-600 text-white px-6 py-2 rounded-xl hover:bg-pink-700">
          Cavab Al
        </button>
      </div>
    </div>
  </div>
</body>
</html>
