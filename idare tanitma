<!DOCTYPE html>
<html lang="az">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Al Eye – Platformalararası Səsli İdarəetmə</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <style>
    .wave { animation: pulse 1s infinite; }
    @keyframes pulse {
      0% { transform: scale(1); opacity: 1; }
      50% { transform: scale(1.1); opacity: 0.5; }
      100% { transform: scale(1); opacity: 1; }
    }
  </style>
</head>
<body class="bg-gray-900 text-white">
  <div class="max-w-4xl mx-auto p-6">
    <div class="bg-gray-800 p-6 rounded-2xl shadow-xl">
      <h1 class="text-3xl font-bold text-blue-400 mb-4">🎤 Al Eye – Cihazlararası Səsli İdarəetmə</h1>

      <!-- Tanıma bölməsi -->
      <div class="mb-6">
        <h2 class="text-xl font-semibold text-green-300">🧠 İstifadəçi Tanınması</h2>
        <p class="text-gray-200">Cihaz: <span id="deviceName" class="font-semibold text-yellow-300">Yüklənir...</span></p>
        <p class="text-gray-400 mt-1">Sistem səni tanıyır və cavab verir.</p>
      </div>

      <!-- Mikrofon aktivlik -->
      <div class="flex items-center space-x-4 mb-6">
        <div class="bg-green-500 p-3 rounded-full wave"></div>
        <p class="text-lg text-white">Mikrofon aktiv – səsli komanda gözlənilir...</p>
      </div>

      <!-- Səsli əmr nəticəsi -->
      <div class="mb-6">
        <h2 class="text-xl font-semibold text-indigo-300">🔊 Əmr Cavabı:</h2>
        <div id="resultText" class="text-yellow-200 mt-2">“Sualınızı verin dostum...”</div>
      </div>

      <!-- Əmr nümunələri -->
      <div class="bg-gray-700 p-4 rounded-xl mt-4">
        <h2 class="text-lg font-semibold text-blue-200">✨ Nümunə Əmrlər:</h2>
        <ul class="list-disc list-inside text-gray-300 mt-2">
          <li>"Al Eye, mən kiməm?"</li>
          <li>"Əhvalım necədir?"</li>
          <li>"Sən harada işləyirsən?"</li>
          <li>"Musiqi çal"</li>
          <li>"Məni tanıyırsan?"</li>
        </ul>
      </div>
    </div>
  </div>

  <!-- JavaScript for voice -->
  <script>
    // Cihaz tanınması
    const deviceName = document.getElementById("deviceName");
    const platform = navigator.platform || "Bilinməyən";
    const userAgent = navigator.userAgent;

    if (/Android/.test(userAgent)) {
      deviceName.textContent = "📱 Android Telefon";
    } else if (/iPhone|iPad/.test(userAgent)) {
      deviceName.textContent = "📱 iOS Cihazı";
    } else if (/TV/.test(userAgent)) {
      deviceName.textContent = "📺 Smart TV";
    } else if (/Win/.test(platform)) {
      deviceName.textContent = "💻 Windows Kompüteri";
    } else {
      deviceName.textContent = "🌐 Veb brauzer";
    }

    // Səsli tanıma və cavab
    const resultText = document.getElementById("resultText");
    window.SpeechRecognition = window.SpeechRecognition || window.webkitSpeechRecognition;

    const recognition = new SpeechRecognition();
    recognition.lang = 'az-AZ'; // Azərbaycan dili dəstəyi varsa
    recognition.interimResults = false;
    recognition.continuous = true;

    recognition.onresult = (e) => {
      const transcript = e.results[e.results.length - 1][0].transcript.trim();
      resultText.textContent = `Sən dedin: "${transcript}"`;

      // Cavab nümunəsi
      if (transcript.includes("mən kiməm")) {
        speak("Sən mənim dostumsan, səni tanıyıram.");
      } else if (transcript.includes("əhvalım")) {
        speak("Səs tonuna görə bir az yorğun görünürsən. Səni dinləyirəm.");
      } else if (transcript.includes("musiqi")) {
        speak("Hazırda sənə rahatladıcı musiqi çalınır.");
      } else {
        speak("Sualını aldım, cavablandırıram.");
      }
    };

    recognition.onerror = (e) => {
      resultText.textContent = `Xəta: ${e.error}`;
    };

    recognition.start();

    function speak(text) {
      const synth = window.speechSynthesis;
      const utter = new SpeechSynthesisUtterance(text);
      utter.lang = 'az-AZ';
      synth.speak(utter);
    }
  </script>
</body>
</html>
