<!DOCTYPE html>
<html lang="az">
<head>
  <meta charset="UTF-8">
  <title>Al Eye - Dayə Modulu</title>
  <style>
    body {
      background: linear-gradient(to bottom right, #ffecd2, #fcb69f);
      font-family: 'Segoe UI', sans-serif;
      color: #333;
      margin: 0;
      padding: 0;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      height: 100vh;
      text-align: center;
    }

    .container {
      padding: 20px;
      border-radius: 15px;
      background: white;
      box-shadow: 0 8px 20px rgba(0,0,0,0.1);
      max-width: 400px;
    }

    h1 {
      font-size: 24px;
      color: #c0392b;
    }

    .nanny-face {
      font-size: 64px;
      margin: 20px 0;
    }

    .voice-response {
      margin-top: 20px;
      padding: 10px;
      background: #ffe4e1;
      border-radius: 10px;
      font-style: italic;
    }

    button {
      margin-top: 15px;
      padding: 10px 20px;
      background-color: #e74c3c;
      color: white;
      border: none;
      border-radius: 10px;
      font-size: 16px;
      cursor: pointer;
    }

    button:hover {
      background-color: #c0392b;
    }
  </style>
</head>
<body>
  <div class="container">
    <div class="nanny-face">👩‍🍼</div>
    <h1>Al Eye - Dayə Modulu</h1>
    <p class="voice-response" id="voice">Salam, mən sənin dayənəm. Bugünkü planımıza birlikdə baxaq!</p>
    <button onclick="speakPlan()">Səsli Bələdçi Aktiv Et</button>
  </div>

  <script>
    function speakPlan() {
      const plan = "Uşaq səhər yeməyini yedi, indi isə oyuncaqlarla oynamalı və saat 12-də yatmalı olacaq.";
      document.getElementById("voice").textContent = plan;
      const utterance = new SpeechSynthesisUtterance(plan);
      utterance.lang = 'az-AZ';
      speechSynthesis.speak(utterance);
    }
  </script>
</body>
</html>
