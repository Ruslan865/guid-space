<!DOCTYPE html>
<html lang="az">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Al Eye – Psixoloq Modulu</title>
  <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-gray-50 text-gray-800">
  <div class="max-w-4xl mx-auto p-6">
    <div class="bg-white rounded-2xl shadow-lg p-6">
      <div class="flex justify-between items-center mb-6">
        <h1 class="text-2xl font-bold text-purple-700">🧠 Al Eye – Psixoloq Modulu</h1>
        <span class="text-sm text-green-600 font-medium">Aktiv Dinləyici</span>
      </div>

      <!-- Emosional vəziyyət seçimi -->
      <div class="mb-6">
        <h2 class="text-xl font-semibold mb-3">Bu gün özünü necə hiss edirsən?</h2>
        <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
          <button class="bg-green-100 hover:bg-green-200 p-4 rounded-xl text-center">
            😊 Xoşbəxt
          </button>
          <button class="bg-yellow-100 hover:bg-yellow-200 p-4 rounded-xl text-center">
            😐 Neytral
          </button>
          <button class="bg-red-100 hover:bg-red-200 p-4 rounded-xl text-center">
            😔 Kədərli
          </button>
          <button class="bg-blue-100 hover:bg-blue-200 p-4 rounded-xl text-center">
            😰 Stressli
          </button>
        </div>
      </div>

      <!-- Söhbət / Emosional dəstək -->
      <div class="mb-6">
        <h2 class="text-xl font-semibold mb-3">Mənə ürəyini aç</h2>
        <textarea
          placeholder="Bugün səni narahat edən bir şey varmı?"
          class="w-full p-4 rounded-xl border border-gray-300 focus:outline-none focus:ring-2 focus:ring-purple-400"
          rows="4"
        ></textarea>
        <button class="mt-4 bg-purple-600 text-white px-6 py-2 rounded-xl hover:bg-purple-700">
          Göndər və Dinlə
        </button>
      </div>

      <!-- Motivasiya Mesajı -->
      <div class="bg-purple-50 p-4 rounded-xl shadow text-center">
        <h3 class="text-lg font-semibold mb-2">Motivasiya Mesajı</h3>
        <p class="italic text-gray-700">“Sən dəyərlisən. Bu duyğular keçicidir. Mən buradayam.”</p>
      </div>
    </div>
  </div>
</body>
</html>
