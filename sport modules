<!DOCTYPE html>
<html lang="az">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Al Eye – İdmançı Modulu</title>
  <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-gray-100 font-sans">
  <div class="max-w-4xl mx-auto p-6">
    <div class="bg-white rounded-2xl shadow-xl p-6">
      <div class="flex items-center justify-between mb-4">
        <h1 class="text-2xl font-bold text-blue-700">🏋️‍♂️ Al Eye – İdmançı Modulu</h1>
        <span class="text-green-600 font-medium">Canlı Aktiv</span>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        <!-- Günlük Plan -->
        <div class="bg-blue-50 p-4 rounded-xl shadow">
          <h2 class="text-xl font-semibold mb-2">Günlük Məşq Planı</h2>
          <ul class="list-disc list-inside text-gray-700">
            <li>30 dəq. Qaçış</li>
            <li>15 dəq. Stretching</li>
            <li>20 dəq. Güc məşqləri</li>
          </ul>
        </div>

        <!-- Bədən Statistikası -->
        <div class="bg-yellow-50 p-4 rounded-xl shadow">
          <h2 class="text-xl font-semibold mb-2">Bədən Statistikası</h2>
          <p>Boy: <strong>175 cm</strong></p>
          <p>Çəki: <strong>68 kg</strong></p>
          <p>BMI: <strong>22.2 (Normal)</strong></p>
        </div>

        <!-- Motivasiya Mesajı -->
        <div class="bg-green-50 p-4 rounded-xl shadow md:col-span-2">
          <h2 class="text-xl font-semibold mb-2">Motivasiya Mesajı</h2>
          <p class="italic text-gray-800">“Hər gün bir addım – gələcəyin sağlam sən!”</p>
        </div>

        <!-- Qrafik və Aktivlik -->
        <div class="bg-purple-50 p-4 rounded-xl shadow md:col-span-2">
          <h2 class="text-xl font-semibold mb-4">Həftəlik Aktivlik</h2>
          <canvas id="activityChart" width="400" height="150"></canvas>
        </div>
      </div>
    </div>
  </div>

  <!-- Chart.js (Həftəlik Aktivlik Qrafiki üçün) -->
  <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
  <script>
    const ctx = document.getElementById('activityChart').getContext('2d');
    const activityChart = new Chart(ctx, {
      type: 'line',
      data: {
        labels: ['B.e.', 'Ç.a.', 'Ç.', 'C.a.', 'C.', 'Ş.', 'B.'],
        datasets: [{
          label: 'Aktiv Saatlar',
          data: [1, 1.5, 0.5, 2, 1.8, 2.5, 1.2],
          backgroundColor: 'rgba(59, 130, 246, 0.2)',
          borderColor: 'rgba(59, 130, 246, 1)',
          borderWidth: 2,
          fill: true,
          tension: 0.4
        }]
      },
      options: {
        responsive: true,
        scales: {
          y: {
            beginAtZero: true,
            title: {
              display: true,
              text: 'Saat'
            }
          }
        }
      }
    });
  </script>
</body>
</html>
